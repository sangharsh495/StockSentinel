# Database (Neon.tech)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/stocksentinel?sslmode=require

# Finnhub API (free at finnhub.io)
FINNHUB_API_KEY=your_finnhub_api_key

# Google Gemini API (free at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key

# Firebase Admin SDK (base64-encoded service account JSON)
FIREBASE_CREDENTIALS=base64_encoded_json_here

# Render external URL (for self-ping keep-alive)
RENDER_EXTERNAL_URL=https://stocksentinel-api.onrender.com
